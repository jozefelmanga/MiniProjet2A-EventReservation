{% extends 'base.html.twig' %}

{% block title %}Events{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Upcoming Events</h1>
        {% if app.user %}
            <span class="text-muted">Welcome, {{ app.user.userIdentifier }}</span>
        {% endif %}
    </div>

    {% if events is empty %}
        <div class="alert alert-info">No events available yet.</div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for event in events %}
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        {% if event.image %}
                            <div class="ratio ratio-16x9">
                                <img src="{{ event.image }}" alt="{{ event.title }}" class="rounded-top" style="object-fit: cover;">
                            </div>
                        {% else %}
                            <div class="ratio ratio-16x9 bg-light d-flex align-items-center justify-content-center text-muted rounded-top">
                                No image
                            </div>
                        {% endif %}
                        <div class="card-body">
                            <h5 class="card-title">{{ event.title }}</h5>
                            <p class="card-subtitle mb-2 text-muted">{{ event.date|date('F j, Y g:i A') }} · {{ event.location }}</p>
                            <p class="card-text">{{ event.description|slice(0, 150) }}{% if event.description|length > 150 %}...{% endif %}</p>
                        </div>
                        <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center">
                            <small class="text-muted">Seats: {{ event.seats }}</small>
                            <a href="#" class="btn btn-sm btn-outline-primary disabled">Details</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
