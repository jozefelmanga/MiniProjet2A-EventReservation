{% extends 'base.html.twig' %}

{% block title %}Reservations · {{ event.title }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Reservations</h1>
            <p class="text-muted mb-0">{{ event.title }} · {{ event.date|date('F j, Y g:i A') }} · {{ event.location }}</p>
        </div>
        <a href="{{ path('admin_events') }}" class="btn btn-outline-secondary">Back to events</a>
    </div>

    {% if reservations is empty %}
        <div class="alert alert-info">Aucune réservation pour cet événement.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Email</th>
                        <th>Téléphone</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for reservation in reservations %}
                        <tr>
                            <td>{{ reservation.name }}</td>
                            <td>{{ reservation.email }}</td>
                            <td>{{ reservation.phone }}</td>
                            <td>{{ reservation.createdAt ? reservation.createdAt|date('Y-m-d H:i') : '' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
