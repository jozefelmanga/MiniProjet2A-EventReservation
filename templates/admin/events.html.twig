{% extends 'base.html.twig' %}

{% block title %}Admin Events{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Manage Events</h1>
        <a href="{{ path('admin_events_new') }}" class="btn btn-success">New Event</a>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% if events is empty %}
        <div class="alert alert-info">No events available.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th style="width: 110px;">Image</th>
                        <th>Title</th>
                        <th>Date</th>
                        <th>Location</th>
                        <th>Seats</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for event in events %}
                        <tr>
                            <td>
                                {% if event.image %}
                                    <img src="{{ event.image }}" alt="{{ event.title }}" style="height:60px;width:100px;object-fit:cover;border-radius:4px;">
                                {% else %}
                                    <span class="badge bg-secondary">No image</span>
                                {% endif %}
                            </td>
                            <td>{{ event.title }}</td>
                            <td>{{ event.date|date('Y-m-d H:i') }}</td>
                            <td>{{ event.location }}</td>
                            <td>{{ event.seats }}</td>
                            <td class="text-end">
                                <a href="{{ path('admin_events_show', {id: event.id}) }}" class="btn btn-sm btn-outline-secondary">View</a>
                                <a href="{{ path('admin_events_edit', {id: event.id}) }}" class="btn btn-sm btn-primary">Edit</a>
                                <a href="{{ path('admin_events_reservations', {id: event.id}) }}" class="btn btn-sm btn-warning">Reservations</a>
                                <form method="post" action="{{ path('admin_events_delete', {id: event.id}) }}" class="d-inline" onsubmit="return confirm('Delete this event?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ event.id) }}">
                                    <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
