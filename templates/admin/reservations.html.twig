{% extends 'base.html.twig' %}

{% block title %}Admin Reservations{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="mb-4">Reservations par événement</h1>

    {% if grouped_reservations is empty %}
        <div class="alert alert-info">No reservations yet.</div>
    {% else %}
        {% for group in grouped_reservations %}
            {% set event = group.event %}
            {% set items = group.items %}
            <div class="card shadow-sm mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <strong>{{ event.title }}</strong>
                        <span class="text-muted">— {{ event.date|date('Y-m-d H:i') }} — {{ event.location }}</span>
                    </div>
                    <span class="badge bg-primary">{{ items|length }} réservation{% if items|length > 1 %}s{% endif %}</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive mb-0">
                        <table class="table table-sm table-striped align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Nom</th>
                                    <th>Email</th>
                                    <th>Téléphone</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for reservation in items %}
                                    <tr>
                                        <td>{{ reservation.name }}</td>
                                        <td>{{ reservation.email }}</td>
                                        <td>{{ reservation.phone }}</td>
                                        <td>{{ reservation.createdAt ? reservation.createdAt|date('Y-m-d H:i') : '' }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endif %}
</div>
{% endblock %}
