{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Admin Dashboard</h1>
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-center p-4">
                <h3>Events</h3>
                <a href="{{ path('admin_events') }}" class="btn btn-primary mt-2">Manage Events</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center p-4">
                <h3>Reservations</h3>
                <a href="{{ path('admin_reservations') }}" class="btn btn-primary mt-2">View Reservations</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}